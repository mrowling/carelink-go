CARELINK_USERNAME=your-carelink-username
CARELINK_PASSWORD=your-carelink-password

# Nightscout config (optional - only needed if uploading to Nightscout)
# By default, data is printed to stdout in JSON format
# API_SECRET=your-nightscout-api-secret
# NS=https://your-nightscout-site.example.com

# CareLink server region (US or EU)
# MMCONNECT_SERVER=EU

# Optional settings
# MMCONNECT_COUNTRYCODE=gb
# MMCONNECT_LANGCODE=en
# CARELINK_INTERVAL=300
# CARELINK_SGV_LIMIT=24
# CARELINK_QUIET=true
# CARELINK_PATIENT=
# USE_PROXY=false
